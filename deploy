#!/bin/bash

SITES_DIR="./sites"
OUTPUT_BASE="./output"

# ── Colours ───────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

print_step()    { echo -e "${BOLD}${CYAN}▸ $1${RESET}"; }
print_success() { echo -e "${GREEN}✔  $1${RESET}"; }
print_error()   { echo -e "${RED}✖  $1${RESET}" >&2; }

# ── Check sites directory exists ──────────────
if [ ! -d "$SITES_DIR" ]; then
  print_error "'$SITES_DIR' directory not found."
  exit 1
fi

# ── Get list of sites ─────────────────────────
sites=()
while IFS= read -r -d '' dir; do
  sites+=("$(basename "$dir")")
done < <(find "$SITES_DIR" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

if [ ${#sites[@]} -eq 0 ]; then
  print_error "No sites found in '$SITES_DIR'."
  exit 1
fi

# ── Pick a site ───────────────────────────────
echo -e "\n${BOLD}Which site do you want to deploy?${RESET}\n"
for i in "${!sites[@]}"; do
  echo -e "  ${CYAN}$((i + 1)))${RESET} ${sites[$i]}"
done
echo ""
read -rp "$(echo -e "${BOLD}Enter number [1-${#sites[@]}]:${RESET} ")" choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#sites[@]} ]; then
  print_error "Invalid selection."
  exit 1
fi

selected="${sites[$((choice - 1))]}"
site_path="$SITES_DIR/$selected"
OUTPUT_DIR="$OUTPUT_BASE/$selected"

# ── Commit message ────────────────────────────
echo ""
read -rp "$(echo -e "${BOLD}Commit message:${RESET} ")" commit_message
commit_message="$(echo "$commit_message" | sed 's/^ *//; s/ *$//')"

if [ -z "$commit_message" ]; then
  print_error "Commit message cannot be empty."
  exit 1
fi

echo ""
print_step "Deploying '$selected'..."
echo ""

# ── Build ─────────────────────────────────────
mkdir -p "$OUTPUT_DIR"

cd "$site_path" || exit 1
mkdocs build
cd - > /dev/null || exit 1

print_success "Site built"

# ── Move build output ─────────────────────────
rm -rf "$OUTPUT_DIR"
mv "$site_path/site" "$OUTPUT_DIR"

print_success "Build output moved to $OUTPUT_DIR"

# ── Stage site source + build output ─────────
git add "$site_path"
git add "$OUTPUT_DIR"

# ── Commit & push ─────────────────────────────
git commit -m "$commit_message"
git push

echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${GREEN}║   Deployed successfully! 🚀          ║${RESET}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════╝${RESET}"
echo -e "
  ${BOLD}Site:${RESET}     $selected
  ${BOLD}Commit:${RESET}   $commit_message
"
